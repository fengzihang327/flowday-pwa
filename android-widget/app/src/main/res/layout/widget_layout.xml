<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✦ flowday"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/w_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#d9f75b"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/w_done"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 / 0"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/w_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="暂无任务"
        android:textColor="#888c8a"
        android:textSize="11sp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/w_tasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Row 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingVertical="3dp">
            <TextView android:id="@+id/w_dot1" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="8dp" android:background="@drawable/dot_default"
                android:text="" android:textColor="#151718" android:textSize="8sp" android:gravity="center" />
            <TextView android:id="@+id/w_label1" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="" android:textColor="#d0d3d1"
                android:textSize="12sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/w_time1" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#6a706d" android:textSize="10sp" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingVertical="3dp">
            <TextView android:id="@+id/w_dot2" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="8dp" android:background="@drawable/dot_default"
                android:text="" android:textColor="#151718" android:textSize="8sp" android:gravity="center" />
            <TextView android:id="@+id/w_label2" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="" android:textColor="#d0d3d1"
                android:textSize="12sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/w_time2" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#6a706d" android:textSize="10sp" />
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingVertical="3dp">
            <TextView android:id="@+id/w_dot3" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="8dp" android:background="@drawable/dot_default"
                android:text="" android:textColor="#151718" android:textSize="8sp" android:gravity="center" />
            <TextView android:id="@+id/w_label3" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="" android:textColor="#d0d3d1"
                android:textSize="12sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/w_time3" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#6a706d" android:textSize="10sp" />
        </LinearLayout>

        <!-- Row 4 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingVertical="3dp">
            <TextView android:id="@+id/w_dot4" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="8dp" android:background="@drawable/dot_default"
                android:text="" android:textColor="#151718" android:textSize="8sp" android:gravity="center" />
            <TextView android:id="@+id/w_label4" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="" android:textColor="#d0d3d1"
                android:textSize="12sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/w_time4" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#6a706d" android:textSize="10sp" />
        </LinearLayout>

        <!-- Row 5 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingVertical="3dp">
            <TextView android:id="@+id/w_dot5" android:layout_width="12dp" android:layout_height="12dp"
                android:layout_marginEnd="8dp" android:background="@drawable/dot_default"
                android:text="" android:textColor="#151718" android:textSize="8sp" android:gravity="center" />
            <TextView android:id="@+id/w_label5" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="" android:textColor="#d0d3d1"
                android:textSize="12sp" android:textStyle="bold"
                android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/w_time5" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="" android:textColor="#6a706d" android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/w_more"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+2 项"
        android:textColor="#5a5f5d"
        android:textSize="10sp"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/w_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="还没有安排"
        android:textColor="#4a4f4d"
        android:textSize="11sp"
        android:visibility="gone" />

</LinearLayout>
